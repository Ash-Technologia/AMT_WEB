# ═══════════════════════════════════════════════════════════════════════════════
# AMT SERVER — PRODUCTION ENVIRONMENT TEMPLATE
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Copy this file to .env on your production server (Render / Railway / VPS)
# 2. Fill in ALL values — do NOT leave any blank
# 3. NEVER commit this file to GitHub (.gitignore already excludes it)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production            # ← MUST be "production" on live server
BACKEND_URL=https://YOUR-SERVER.onrender.com   # ← Your actual server URL

# ─── Client (CORS) ────────────────────────────────────────────────────────────
# This MUST match your deployed frontend URL exactly (no trailing slash)
CLIENT_URL=https://amt-therapy.vercel.app       # ← Your actual frontend URL

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Use the connection string from Atlas → Clusters → Connect → Drivers
# Recommended: Upgrade to M10 or higher for production traffic
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/amt_prod?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# CHANGE THIS to a NEW random 64-character string for production security
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_A_NEW_64_CHAR_RANDOM_STRING_HERE
JWT_EXPIRE=7d

# ─── Cloudinary (Image Hosting) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Gmail (Transactional Email) ──────────────────────────────────────────────
# Use a Gmail App Password (not your regular Gmail password)
# Enable 2FA → Google Account → Security → App Passwords → Create
GMAIL_USER=your_business_email@gmail.com
GMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# ─── Admin Notifications ──────────────────────────────────────────────────────
ADMIN_EMAIL=your_admin_email@gmail.com
ADMIN_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── AI Keys (optional — only if AI chat is enabled) ─────────────────────────
GEMINI_API_KEY=your_gemini_key
GROQ_API_KEY=your_groq_key

# ─── Twilio (optional — only if SMS OTP is enabled) ──────────────────────────
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE=+91XXXXXXXXXX

# ═══════════════════════════════════════════════════════════════════════════════
# SSL/HTTPS NOTES
# ═══════════════════════════════════════════════════════════════════════════════
# - Render.com & Railway.app: HTTPS is automatic — no extra config needed
# - Custom VPS (Ubuntu): Run: sudo certbot --nginx -d yourdomain.com
#   Install: sudo apt install certbot python3-certbot-nginx
# - Vercel (frontend): HTTPS is automatic
# ═══════════════════════════════════════════════════════════════════════════════
